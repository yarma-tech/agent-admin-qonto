# Qonto API credentials — one instance per client
QONTO_ORGANIZATION_SLUG=your-organization-slug
QONTO_SECRET_KEY=your-secret-key

# Shared secret used by the central agent to authenticate requests to this proxy
SHARED_TOKEN=change-me-to-a-long-random-string

# WebSocket URL of the central agent (optional, used for push notifications)
CENTRAL_WS_URL=
