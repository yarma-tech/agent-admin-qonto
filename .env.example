# Qonto API credentials
# Get these from https://app.qonto.com/ → Settings → Integrations
# Required scopes:
#   client_invoice.write, client_invoices.read
#   client.write, client.read
#   product.write, product.read
#   organization.read
QONTO_ORGANIZATION_SLUG=your-org-slug
QONTO_SECRET_KEY=your-secret-key
